# =====================================================================
# Resumi — env template.
# Copy this file to `.env.local` and fill in secrets. `.env.local` is
# gitignored. Uncomment ONE of the two DB blocks below.
# =====================================================================

# -------- Option A: Local Supabase via Docker (recommended) --------
# Run `npm run sb:start` once to launch the stack on ports 55321-55324.
# The stack emits these values; paste them here after the first start.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-anon-key-from-`npm-run-sb:status`>
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres

# -------- Option B: Cloud Supabase (legacy) --------
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# DATABASE_URL=postgresql://postgres.your-project-ref:YOUR-PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres

# -------- AI (Google Gemini) --------
GOOGLE_GENERATIVE_AI_API_KEY=your-gemini-api-key
